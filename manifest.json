{
  "manifest_version": 3,
  "name": "拾页 · AI 智能书签",
  "version": "1.0.0",
  "description": "本地优先的 AI 智能书签管理器：自动分类、摘要、标签与搜索，并与 Chrome 原生书签联动。",
  "permissions": ["storage", "tabs", "activeTab", "contextMenus", "scripting", "history", "idle", "bookmarks", "alarms"],
  "host_permissions": ["<all_urls>"],
  "icons": {
    "16": "icons/logo-16.png",
    "32": "icons/logo-32.png",
    "48": "icons/logo-48.png",
    "128": "icons/logo-128.png"
  },
  "action": {
    "default_title": "拾页",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/logo-16.png",
      "32": "icons/logo-32.png",
      "48": "icons/logo-48.png",
      "128": "icons/logo-128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "options_page": "options.html"
}
